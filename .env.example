# ─────────────────────────────────────────────
#  Holy Grills — Environment Variables
#  Copy to .env and fill in real values.
#  REQUIRED vars must be set before launch.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
# REQUIRED
SECRET_KEY=change-me-to-a-long-random-string

# JWT signing secret for local token operations.
# Set this to the value shown in Supabase Dashboard → Settings → API → JWT Secret.
# If left as a different value, the refresh-endpoint TTL optimisation still works
# correctly (it decodes without signature verification). All auth security goes
# through Supabase's own token validation.
JWT_SECRET=change-me-to-match-supabase-jwt-secret
SUPABASE_JWT_SECRET=                  # Alternative name — used if JWT_SECRET is not set

# Optional (defaults shown)
APP_NAME=Holy Grills
APP_TAGLINE=Holy Grills FUTA
FLASK_DEBUG=false
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGINS=https://your-frontend.vercel.app
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000
JWT_REFRESH_WINDOW_MINUTES=5          # Rotate token when < N minutes remain before expiry

# ── Supabase ──────────────────────────────────
# REQUIRED
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── Payments — Paystack ───────────────────────
# REQUIRED for card payments and virtual accounts
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret
PAYSTACK_PREFERRED_BANK=wema-bank

# ── Payments — Flutterwave ────────────────────
# Optional (used for alternative payment gateway)
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-...
FLUTTERWAVE_WEBHOOK_SECRET=your-flutterwave-webhook-secret

# ── Notifications — OneSignal ─────────────────
# REQUIRED for push and email notifications
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_API_KEY=os_v2_...
EMAIL_FROM=noreply@holygrills.ng
EMAIL_FROM_NAME=Holy Grills

# ── Redis / Celery ────────────────────────────
# REQUIRED for background jobs (birthday HP, leaderboard reset, etc.)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── HP Economy ────────────────────────────────
# These have safe defaults — only set to override

# Core earn rates
HP_PER_NAIRA_FOOD=0.1          # 1 HP per ₦10 food spend
HP_LIABILITY_VALUE=0.185       # ₦ value of 1 HP for accounting
HP_UNLOCK_RATE=100             # HP unlocked per ₦1,000 food spend

# Pending pool
PENDING_CEILING_RATIO=0.35     # Max pending = 35% of active balance
PENDING_FLOOR_HP=200           # Minimum pending ceiling (HP)

# HP Award amounts
SIGNUP_BONUS_HP=0              # HP granted on account creation (0 = disabled)
WELCOME_BONUS_HP=50            # HP granted on first order delivery
REVIEW_HP=20
REFERRAL_HP=75
EVENT_CHECKIN_HP=40
BIRTHDAY_HP=150
WALLET_TOPUP_HP=50
WALLET_TOPUP_MIN=3000
SUBSCRIPTION_HP=50
SOCIAL_SHARE_HP=25
MARKETPLACE_PURCHASE_HP=50  # HP awarded when a marketplace item is purchased

# Referral milestones
REFERRAL_MILESTONE_1_COUNT=5
REFERRAL_MILESTONE_2_COUNT=10
REFERRAL_MILESTONE_5_HP=150
REFERRAL_MILESTONE_10_HP=400

# Flash redemption
FLASH_DISCOUNT_PCT=0.50        # 50% discount on flash deals
FLASH_MAX_QTY=5                # Max redemptions per flash window

# HP Bundle (event hosts)
HP_BUNDLE_PRICE_PER_HP=5.0     # ₦5 per HP

# HP Expiry
HP_EXPIRY_INACTIVITY_DAYS=90
HP_EXPIRY_BREAKAGE_RATE=0.25   # 25% of balance expires after inactivity
HP_EXPIRY_WARNING_EARLY_DAYS=14
HP_EXPIRY_WARNING_LATE_DAYS=3

# Tier system
TIER_GRACE_PERIOD_DAYS=7

# Event / Challenge caps
EVENT_CHECKIN_CAP_PER_MONTH=3
CHALLENGE_MAX_HP_REWARD=100

# ── Wallet ────────────────────────────────────
WALLET_MIN_CARD_TOPUP=100      # Minimum card top-up in ₦

# ── Spin Wheel ────────────────────────────────
SPIN_COST_HP=10

# ── Rewards ───────────────────────────────────
REWARD_FULFILMENT_HOURS=24     # Hours quoted in reward redemption confirmation email

# ── Marketplace / Cart ────────────────────────
LOW_CODE_INVENTORY_THRESHOLD=5
ABANDONED_CART_MINUTES=60

# ── Squad Order ────────────────────────────────
# A single order with >= SQUAD_ORDER_MIN_ITEMS item qty qualifies for squad
# discounts. Both delivery-fee and subtotal discounts can be toggled independently.
SQUAD_ORDER_ENABLED=true          # Master toggle
SQUAD_ORDER_MIN_ITEMS=3           # Min total item qty to qualify
SQUAD_ORDER_MAX_ITEMS=20          # Max total item qty (upper bound)
SQUAD_DELIVERY_DISCOUNT_ENABLED=true   # Waive/reduce delivery fee
SQUAD_DELIVERY_DISCOUNT_PCT=100        # % of delivery fee waived (100 = free delivery)
SQUAD_ORDER_DISCOUNT_ENABLED=false     # Apply % discount on subtotal
SQUAD_ORDER_DISCOUNT_PCT=10            # % discount on subtotal when enabled

# ── Rate limits (per IP, requests / window_seconds) ───
# All have safe defaults. Only set to override.
RATE_LIMIT_REGISTER_REQUESTS=10
RATE_LIMIT_REGISTER_WINDOW=3600
RATE_LIMIT_LOGIN_REQUESTS=20
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_REFRESH_REQUESTS=30        # Sliding-window token refresh calls per minute
RATE_LIMIT_REFRESH_WINDOW=60
RATE_LIMIT_VERIFY_EMAIL_REQUESTS=3    # Resend verification email calls per hour
RATE_LIMIT_VERIFY_EMAIL_WINDOW=3600
RATE_LIMIT_DEVICE_TOKEN_REQUESTS=20  # Device token registrations per hour per IP
RATE_LIMIT_DEVICE_TOKEN_WINDOW=3600
RATE_LIMIT_RESET_PW_REQUESTS=5
RATE_LIMIT_RESET_PW_WINDOW=3600

# ── OneSignal base (override only for testing) ─
ONESIGNAL_BASE_URL=https://api.onesignal.com

# ── Login streak weekly completion bonuses ────────────────────────────────────
LOGIN_STREAK_WEEK1_HP=25
LOGIN_STREAK_WEEK2_HP=40
LOGIN_STREAK_WEEK3_HP=60
LOGIN_STREAK_WEEK4_HP=80

# ── Streak tolerance & reclaim ────────────────────────────────────────────────
STREAK_MAX_MISSED_DAYS=2         # Missed days per 7-day cycle before streak breaks
STREAK_RECLAIM_MIN_TOPUP=1000   # Min ₦ wallet top-up to reclaim a missed day

# ── Notification throttle ─────────────────────────────────────────────────────
NOTIFICATION_GAP_MINUTES=30      # Min minutes between same-type notifications per user
NOTIFICATION_DAILY_CAP=20        # Max non-critical notifications per user per day

# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_MIN_WITHDRAWAL=500        # Minimum withdrawal amount in ₦
